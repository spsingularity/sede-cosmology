.DS_Store
__pycache__/
*.pyc
.venv/

# LaTeX build intermediates (regenerated by paper/build.sh; the final PDF is committed separately)
paper/tex/*.aux
paper/tex/*.log
paper/tex/*.blg
paper/tex/*.bbl
paper/tex/*.out
paper/tex/*.toc
paper/tex/*.fls
paper/tex/*.fdb_latexmk
paper/tex/*.synctex.gz
paper/tex/*.build.log
paper/tex/*Notes.bib
paper/tex/*.pdf

# run logs (MCMC / calibration)
results/logs/

# CAMB E(z)/D_C(z) table cache (regenerated by the inference drivers)
cache/

# large regenerable MCMC chain dumps from run_model_comparison.py
# (the small curated barrow chains are tracked; these 5–8 MB CPL/free-shape
# chains are not — regenerate with `python src/experiments/run_model_comparison.py`)
results/model_chain_*.npy
